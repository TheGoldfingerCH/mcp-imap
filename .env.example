# =====================================================================
# mcp-imap — environment variables
# =====================================================================
# Copy to .env and fill in your values — NEVER commit .env

# ── Default account ───────────────────────────────────────────────────
MAIL_IMAP_HOST=imap.example.com
MAIL_IMAP_PORT=993

MAIL_SMTP_HOST=smtp.example.com
MAIL_SMTP_PORT=587

MAIL_USER=you@yourdomain.com
MAIL_PASS=your_password
MAIL_FROM=you@yourdomain.com

# ── Additional accounts (optional) ───────────────────────────────────
# Pattern: MAIL_<ACCOUNT>_* where <ACCOUNT> is the name you'll use in tools
# Example: account="pro" → use MAIL_PRO_* variables

# MAIL_PRO_IMAP_HOST=imap.yourprovider.com
# MAIL_PRO_IMAP_PORT=993
# MAIL_PRO_SMTP_HOST=smtp.yourprovider.com
# MAIL_PRO_SMTP_PORT=587
# MAIL_PRO_USER=pro@yourdomain.com
# MAIL_PRO_PASS=your_pro_password
# MAIL_PRO_FROM=pro@yourdomain.com

# MAIL_PERSO_IMAP_HOST=imap.gmail.com
# MAIL_PERSO_IMAP_PORT=993
# MAIL_PERSO_SMTP_HOST=smtp.gmail.com
# MAIL_PERSO_SMTP_PORT=587
# MAIL_PERSO_USER=you@gmail.com
# MAIL_PERSO_PASS=your_app_password
# MAIL_PERSO_FROM=you@gmail.com
