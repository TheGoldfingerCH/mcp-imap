# =====================================================================
# TOOL_MCP_IMAP — variables d'environnement
# =====================================================================
# Copier en .env et remplir les valeurs — NE JAMAIS COMMITTER .env

# --- IMAP (lecture des mails) ---
MAIL_IMAP_HOST=imap.example.com
MAIL_IMAP_PORT=993

# --- SMTP (envoi des mails) ---
MAIL_SMTP_HOST=imap.example.com
MAIL_SMTP_PORT=587

# --- Credentials ---
MAIL_USER=ton.adresse@tondomaine.ch
MAIL_PASS=ton_mot_de_passe
MAIL_FROM=ton.adresse@tondomaine.ch

# --- Génériques ---
LOG_LEVEL=INFO
